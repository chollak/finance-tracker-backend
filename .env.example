# Application Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
# Choose: sqlite or supabase
DATABASE_TYPE=sqlite

# Supabase Configuration (required only when DATABASE_TYPE=supabase)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
# Server-side only; do not expose to the webapp
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_ORG_ID=
OPENAI_MODEL=gpt-4-turbo
WHISPER_MODEL=whisper-1
DEFAULT_LANGUAGE=ru

# Telegram Bot
TG_BOT_API_KEY=your-telegram-bot-token
WEB_APP_URL=http://localhost:3000
# Optional: chat/user id used by npm run dev:miniapp / miniapp:menu helpers to update Telegram menu button
MINIAPP_CHAT_ID=
# Optional: use an ngrok URL in local development; AppConfig prefers it when NODE_ENV=development
NGROK_URL=

# Development Settings
# Telegram polling is enabled by default; set false to run API without bot polling.
ENABLE_TELEGRAM_POLLING=true
# Reserved for webhook deployments; when true, polling launch is skipped.
WEBHOOK_MODE=false
DOWNLOADS_PATH=./downloads

# Logging Configuration
# Levels: error, warn, info, debug
LOG_LEVEL=info
